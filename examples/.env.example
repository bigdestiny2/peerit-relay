# peerit-relay environment — copy to /etc/peerit-relay.env and edit.
# Referenced by examples/peerit-relay.service (EnvironmentFile=).
# Anything left unset uses the built-in default shown in the README.

# --- core ---
PORT=8787
HOST=127.0.0.1                       # loopback only; the reverse proxy reaches it here
PEERIT_RELAY_CORE=memory             # 'memory' (ephemeral) | 'hypercore' (DHT-replicated)
# PEERIT_RELAY_STORAGE=/var/lib/peerit-relay/store   # only for the hypercore core

# --- trust / auth ---
# A fixed secret so tokens survive restarts; SAME value on every replica.
# Generate once:  openssl rand -hex 32
PEERIT_RELAY_SECRET=CHANGEME_openssl_rand_hex_32
PEERIT_RELAY_ORIGINS=https://peerit.site      # CORS allowlist (comma-separated); never leave at '*' in prod
PEERIT_RELAY_TRUST_PROXY=1                     # set ONLY because Caddy/nginx sets a trustworthy X-Forwarded-For

# --- abuse limits (open-internet hardening) ---
PEERIT_RELAY_MAX_RATE=300            # requests/min per IP before 429
PEERIT_RELAY_SSE_PER_IP=8            # max concurrent event streams per IP
PEERIT_RELAY_MAX_BYTES=256           # in-memory record budget (MiB) before 503
PEERIT_RELAY_MAX_GROUPS=20000        # max distinct outboxes before 503
NODE_ENV=production
